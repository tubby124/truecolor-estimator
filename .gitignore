# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Pricing CSV backups
data/tables/*.csv.bak

# SEO wave-audit script output (scripts/seo-wave-audit.mjs)
# Outputs to stdout; some runs redirect to memory/. Files are transient analysis,
# not source. Vault copies live in Projects/true-color/SEO/.
memory/seo-wave-audit-*.txt
memory/seo-wave-audit-*.json

# Editor directories
.idea/
.vscode/
*.swp
*.swo

# Supabase local state
supabase/.temp/

# E2E test artifacts
e2e-screenshots/
playwright-report/
test-results/
playwright/.auth/

# local-only Claude Code settings (per-machine hooks/MCP toggles)
.claude/settings.local.json
