{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hooks/price-guard.mjs"
          },
          {
            "type": "command",
            "command": "node scripts/hooks/seo-wave-guard.mjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hooks/post-edit-price-check.mjs"
          },
          {
            "type": "command",
            "command": "node scripts/hooks/seo-cooldown-check.mjs"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hooks/stop-price-validation.mjs"
          }
        ]
      }
    ]
  }
}
