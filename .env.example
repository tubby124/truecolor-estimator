# App
NEXT_PUBLIC_SITE_URL=https://truecolorprinting.ca
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# Server-side UPLOAD_CLICKS action IDs. These are the durable paid-revenue
# actions used by the conversion outbox; keep campaigns paused until both are
# verified in customer 1072816342 and observed end to end.
GOOGLE_ADS_PURCHASE_CONVERSION_ACTION_ID=
GOOGLE_ADS_QUOTE_WON_CONVERSION_ACTION_ID=
# Secondary, duration-qualified call action. Do not use a raw phone-click action.
GOOGLE_ADS_QUALIFIED_CALL_CONVERSION_ACTION_ID=

# Google Ads API credentials for the read-only verifier and fail-closed spend
# monitor. The route is allowlisted in code to True Color customer 1072816342
# and the three canonical campaign IDs; never put real credentials in this file.
GOOGLE_ADS_CLIENT_ID=your-google-oauth-client-id
GOOGLE_ADS_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_ADS_REFRESH_TOKEN=your-google-oauth-refresh-token
GOOGLE_ADS_DEVELOPER_TOKEN=your-google-ads-developer-token
GOOGLE_ADS_MONITOR_PROFILE=public-pilot
# Required only while GOOGLE_ADS_MONITOR_PROFILE=controlled-test. Regina local
# time, whole-hour format, maximum 72 hours.
GOOGLE_ADS_CONTROLLED_TEST_WINDOW_START=2026-07-20T08:00
GOOGLE_ADS_CONTROLLED_TEST_WINDOW_END=2026-07-23T08:00

# Shared bearer used by scheduled /api/cron/* calls.
CRON_SECRET=replace-with-a-long-random-secret

# GA4 Data API snapshots for /api/cron/ga4-sync.
# GA4_PROPERTY_ID is the numeric property ID, not the G- measurement ID.
# GA4_SERVICE_ACCOUNT_JSON must be a service-account JSON object with
# Analytics Viewer access to that GA4 property. In Railway this can point at
# an existing service account variable, e.g. ${{GOOGLE_SERVICE_ACCOUNT_JSON}}.
GA4_PROPERTY_ID=123456789
GA4_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# CRA GST registration number — shown on receipts, quote docs, and email footers
NEXT_PUBLIC_GST_NUMBER=731454914RT0001

# ─── Email (Hostinger SMTP) — Phase 2 ────────────────────────────────────────
# Set these in Railway dashboard → Variables (never commit real values)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@true-color.ca
SMTP_PASS=your-email-password-here
SMTP_FROM=True Color Display Printing <info@true-color.ca>
SMTP_BCC=info@true-color.ca

# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-secret-key

# ─── Wave Accounting API (Phase 3) ───────────────────────────────────────────
WAVE_API_KEY=your-wave-api-key

# ─── Clover POS (Phase 4) ─────────────────────────────────────────────────────
CLOVER_API_KEY=your-clover-api-key
# CLOVER_WEBHOOK_SECRET — register webhook in Clover Dashboard with URL:
#   https://truecolorprinting.ca/api/webhooks/clover?k=<this-value>
# If unset, the webhook endpoint accepts all requests without auth.
CLOVER_WEBHOOK_SECRET=your-webhook-secret-here

# ─── Staff access (temporary until proper auth) ───────────────────────────────
STAFF_PASSWORD=change-me-before-deploy
