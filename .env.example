# App
NEXT_PUBLIC_SITE_URL=https://truecolorprinting.ca
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# GA4 Data API snapshots for /api/cron/ga4-sync.
# GA4_PROPERTY_ID is the numeric property ID, not the G- measurement ID.
# GA4_SERVICE_ACCOUNT_JSON must be a service-account JSON object with
# Analytics Viewer access to that GA4 property. In Railway this can point at
# an existing service account variable, e.g. ${{GOOGLE_SERVICE_ACCOUNT_JSON}}.
GA4_PROPERTY_ID=123456789
GA4_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# CRA GST registration number — shown on receipts, quote docs, and email footers
NEXT_PUBLIC_GST_NUMBER=731454914RT0001

# ─── Transactional email (Resend HTTPS API) ─────────────────────────────────
# Set these in Railway dashboard → Variables (never commit real values).
RESEND_API_KEY=re_xxxxxxxxx
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxx
SMTP_FROM=True Color Display Printing <hello@outreach.true-color.ca>
SMTP_REPLY_TO=info@true-color.ca
SMTP_BCC=info@true-color.ca

# Order-reply tracking. Keep both flags false until a controlled probe proves
# info+o_<token>@true-color.ca reaches the info@ Workspace mailbox with the
# token preserved in To, Delivered-To, or X-Original-To.
ORDER_REPLY_TOKEN_ENABLED=false
ORDER_REPLY_SYNC_ENABLED=false

# Google Workspace service account with domain-wide delegation. The deployed
# grant currently uses the exact gmail.modify scope; the app only reads mail.
GMAIL_SA_CLIENT_EMAIL=service-account@project.iam.gserviceaccount.com
GMAIL_SA_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
GMAIL_IMPERSONATE_EMAIL=info@true-color.ca
CRON_SECRET=replace-with-a-long-random-secret

# ─── Supabase (Phase 3 — not yet active) ─────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ─── Wave Accounting API (Phase 3) ───────────────────────────────────────────
WAVE_API_KEY=your-wave-api-key

# ─── Clover POS (Phase 4) ─────────────────────────────────────────────────────
CLOVER_API_KEY=your-clover-api-key
# CLOVER_WEBHOOK_SECRET — register webhook in Clover Dashboard with URL:
#   https://truecolorprinting.ca/api/webhooks/clover?k=<this-value>
# If unset, the webhook endpoint accepts all requests without auth.
CLOVER_WEBHOOK_SECRET=your-webhook-secret-here

# ─── Staff access (temporary until proper auth) ───────────────────────────────
STAFF_PASSWORD=change-me-before-deploy
